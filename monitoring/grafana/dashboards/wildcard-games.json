{
    "uid": "wildcard-games",
    "title": "Wildcard — Métier (jeux)",
    "tags": ["wildcard", "métier"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "editable": true,
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" },
    "templating": { "list": [] },
    "annotations": { "list": [] },
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "Parties actives",
            "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "steps": [{ "color": "green", "value": null }]
                    }
                },
                "overrides": []
            },
            "options": {
                "colorMode": "value",
                "graphMode": "area",
                "reduceOptions": { "calcs": ["lastNotNull"] }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum(wildcard_active_games)",
                    "legendFormat": "actives"
                }
            ]
        },
        {
            "id": 2,
            "type": "stat",
            "title": "Parties démarrées (plage)",
            "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "options": {
                "colorMode": "value",
                "graphMode": "area",
                "reduceOptions": { "calcs": ["lastNotNull"] }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum(increase(wildcard_games_started_total[$__range]))",
                    "legendFormat": "démarrées"
                }
            ]
        },
        {
            "id": 3,
            "type": "stat",
            "title": "Parties terminées (plage)",
            "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "options": {
                "colorMode": "value",
                "graphMode": "area",
                "reduceOptions": { "calcs": ["lastNotNull"] }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum(increase(wildcard_games_finished_total[$__range]))",
                    "legendFormat": "terminées"
                }
            ]
        },
        {
            "id": 4,
            "type": "stat",
            "title": "Taux d'abandon (plage)",
            "description": "1 − parties terminées / parties démarrées sur la plage de temps. Une partie démarrée mais jamais terminée est considérée abandonnée.",
            "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "color": { "mode": "thresholds" },
                    "thresholds": {
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "orange", "value": 0.3 },
                            { "color": "red", "value": 0.6 }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "colorMode": "value",
                "graphMode": "none",
                "reduceOptions": { "calcs": ["lastNotNull"] }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "1 - (sum(increase(wildcard_games_finished_total[$__range])) / clamp_min(sum(increase(wildcard_games_started_total[$__range])), 1))",
                    "legendFormat": "abandon"
                }
            ]
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "Parties actives par jeu",
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 15,
                        "stacking": { "mode": "normal" }
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "right",
                    "calcs": ["lastNotNull", "max"]
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum by (module) (wildcard_active_games)",
                    "legendFormat": "{{module}}"
                }
            ]
        },
        {
            "id": 6,
            "type": "timeseries",
            "title": "Durée moyenne d'une partie par jeu",
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": { "drawStyle": "line", "fillOpacity": 10 }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "right",
                    "calcs": ["lastNotNull"]
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum by (module) (rate(wildcard_game_duration_seconds_sum[$__rate_interval])) / clamp_min(sum by (module) (rate(wildcard_game_duration_seconds_count[$__rate_interval])), 0.0001)",
                    "legendFormat": "{{module}}"
                }
            ]
        },
        {
            "id": 7,
            "type": "timeseries",
            "title": "Latence d'application d'un coup (p50 / p95)",
            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "custom": { "drawStyle": "line", "fillOpacity": 10 }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": ["lastNotNull", "max"]
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "histogram_quantile(0.5, sum by (le) (rate(wildcard_move_duration_ms_bucket[$__rate_interval])))",
                    "legendFormat": "p50"
                },
                {
                    "refId": "B",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "histogram_quantile(0.95, sum by (le) (rate(wildcard_move_duration_ms_bucket[$__rate_interval])))",
                    "legendFormat": "p95"
                }
            ]
        },
        {
            "id": 8,
            "type": "timeseries",
            "title": "Coups par seconde, par résultat",
            "description": "Débit des actions soumises à l'API. result=ok = coups valides ; rule_violation / version_conflict / invalid_action / db_error = erreurs.",
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "fieldConfig": {
                "defaults": {
                    "unit": "ops",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 15,
                        "stacking": { "mode": "normal" }
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "right",
                    "calcs": ["lastNotNull"]
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "prometheus", "uid": "prometheus" },
                    "expr": "sum by (result) (rate(wildcard_moves_total[$__rate_interval]))",
                    "legendFormat": "{{result}}"
                }
            ]
        }
    ]
}
