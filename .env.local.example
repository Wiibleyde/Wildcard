# ── Local dev (supabase start) ──────────────────────────────────────────────
# Config publique lue au RUNTIME (src/lib/public-env.ts) — plus de NEXT_PUBLIC_*.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<copy from: supabase status>

# Server-only — bypasses RLS so the game engine can read/write the full secret
# state (every hand, the RNG seed). Required for multiplayer. NEVER expose to
# the browser. Local value = SERVICE_ROLE_KEY in .env.docker (or `supabase status`).
SUPABASE_SERVICE_ROLE_KEY=<copy from: supabase status / .env.docker>

# Laisser vide en dev → /api/metrics reste ouvert (pas de Prometheus en local).
# En prod, définir le même token côté app et côté Prometheus. openssl rand -hex 32
# METRICS_TOKEN=

# ── Production ───────────────────────────────────────────────────────────────
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_ANON_KEY=<anon-key from dashboard>
# UMAMI_URL=https://umami.<domaine>
# UMAMI_WEBSITE_ID=<id du site Umami>

# ── OAuth providers (local dev — set in supabase/config.toml too) ────────────
# Google: https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# Discord: https://discord.com/developers/applications
SUPABASE_AUTH_DISCORD_CLIENT_ID=
SUPABASE_AUTH_DISCORD_SECRET=

# ── OAuth redirect URL to register in each provider's console ───────────────
#   Local:  http://127.0.0.1:54321/auth/v1/callback
#   Prod:   https://<ref>.supabase.co/auth/v1/callback
