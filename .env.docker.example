############################################################
# Wildcard — Docker Compose (Supabase + app Next.js)
# Usage : docker compose --env-file .env.docker up -d
# Copier dans .env.docker et remplir les valeurs. NE PAS COMMITER.
############################################################

# ── Postgres ──────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=your-super-secret-db-password

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
JWT_EXPIRY=3600
SECRET_KEY_BASE=your-secret-key-base-for-realtime

# ── API Keys (generated from JWT_SECRET) ─────────────────
# Use: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=<generated-anon-jwt>
SERVICE_ROLE_KEY=<generated-service-role-jwt>

# ── URLs ──────────────────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/auth/callback

# ── App image (CD) ───────────────────────────────────────
# Laisser vide en local (l'image est buildée par `up --build`).
# En prod/CD : pointer sur l'image publiée par la pipeline GHCR.
#   APP_IMAGE=ghcr.io/wiibleyde/wildcard:latest
APP_IMAGE=

# ── Kong ports ────────────────────────────────────────────
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=54322

# ── Studio ────────────────────────────────────────────────
STUDIO_PORT=54323
STUDIO_DEFAULT_ORGANIZATION=Wildcard
STUDIO_DEFAULT_PROJECT=Wildcard Dev
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# ── Inbucket (local email) ────────────────────────────────
INBUCKET_PORT=54324

# ── PostgREST ─────────────────────────────────────────────
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ── Auth signup flags ─────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false

# ── SMTP (local dev → use inbucket) ──────────────────────
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-inbucket
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=Wildcard

# ── Auth email paths ──────────────────────────────────────
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# ── OAuth providers ───────────────────────────────────────
# Register redirect URL in each provider console:
#   http://localhost:54321/auth/v1/callback

ENABLE_DISCORD_SIGNUP=false
SUPABASE_AUTH_DISCORD_CLIENT_ID=
SUPABASE_AUTH_DISCORD_SECRET=

ENABLE_GOOGLE_SIGNUP=false
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# ── Analytics ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
LOGFLARE_API_KEY=your-logflare-api-key

# ── Monitoring stack (profil `monitoring`) ───────────────
# docker compose --env-file .env.docker --profile monitoring up -d
# Umami (analytics web cookieless) + Prometheus + Grafana.

# Ports hôte
UMAMI_PORT=54325
PROMETHEUS_PORT=54326
GRAFANA_PORT=54327

# Umami — generate each with: openssl rand -hex 16  /  openssl rand -base64 32
UMAMI_DB_PASSWORD=change-me-umami-db-password
UMAMI_APP_SECRET=change-me-umami-app-secret

# Grafana — login admin du dashboard
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Bearer token protégeant /api/metrics (port app publié → joignable de l'extérieur).
# Prometheus l'envoie automatiquement. Generate with: openssl rand -hex 32
METRICS_TOKEN=change-me-metrics-token

# Tag Umami injecté dans l'app au RUNTIME (window.__PUBLIC_ENV__). Laisser le
# WEBSITE_ID vide tant que le site n'est pas créé dans l'UI Umami ; sans lui le
# tag ne se charge pas. UMAMI_URL doit être joignable depuis le navigateur.
UMAMI_URL=http://localhost:54325
UMAMI_WEBSITE_ID=
