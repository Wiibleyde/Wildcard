{
    "name": "wildcard",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "docker compose --env-file .env.docker --profile studio up -d --scale app=0 && bun run db:migrate && next dev",
        "build": "next build",
        "start": "next start",

        "lint": "biome check",
        "format": "biome format --write",
        "test": "vitest run",
        "test:watch": "vitest",

        "up": "docker compose --env-file .env.docker up -d && bun run db:migrate",
        "down": "docker compose --env-file .env.docker down",
        "docker:build": "docker compose --env-file .env.docker build",
        "docker:up": "docker compose --env-file .env.docker up -d",
        "docker:down": "docker compose --env-file .env.docker down",

        "db:migrate": "bash scripts/db-migrate.sh",
        "db:new-migration": "supabase migration new",
        "db:push": "supabase db push",
        "db:reset": "supabase db reset",
        "db:types": "supabase gen types typescript --local > src/lib/supabase/types.ts"
    },
    "dependencies": {
        "@gsap/react": "^2.1.2",
        "@supabase/ssr": "0.10.3",
        "@supabase/supabase-js": "2.106.2",
        "gsap": "^3.15.0",
        "next": "16.2.6",
        "next-intl": "^4.13.0",
        "prom-client": "^15.1.3",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "playwright": "^1.60.0",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^4.1.8"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "sharp",
        "unrs-resolver"
    ]
}
